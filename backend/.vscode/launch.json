{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: dev (reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false,
      "python": "${workspaceFolder}/.venv/bin/python"
    },
    {
      "name": "FastAPI: run (no reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "jinja": true,
      "justMyCode": false,
      "python": "${workspaceFolder}/.venv/bin/python"
    }
  ]
}
